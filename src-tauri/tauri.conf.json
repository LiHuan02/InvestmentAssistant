{
  "productName": "InvestmentAssistant",
  "version": "1.0.3",
  "identifier": "com.investment.assistant",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "市场投资助手",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8000 ws://127.0.0.1:8000; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/investment-backend"
    ],
    "resources": [
      "../.env.example",
      "../backend/mcp_config.yaml"
    ]
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "binaries/investment-backend",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
