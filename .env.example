# AI 设置（必填，支持 OpenAI 兼容接口）
AI_API_KEY=sk-your-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Tavily 联网搜索（可选，https://tavily.com 注册免费 1000次/月）
TAVILY_API_KEY=

# TwelveData API（可选，用于全球指数K线）
TWELVEDATA_API=

# RAG 知识库（可选，设置持久化目录后自动启用 ChromaDB）
RAG_PERSIST_DIR=

# MCP 服务 API Keys（在 backend/mcp_config.yaml 中启用对应服务后填写）
# ALPHAVANTAGE_API_KEY=
# BRAVE_API_KEY=
# FINANCIAL_DATASETS_API_KEY=

# 服务设置
PORT=8000
MARKET_REFRESH_INTERVAL=60
NEWS_REFRESH_INTERVAL=300
